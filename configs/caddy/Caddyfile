{
	# TailScale Serve terminates tailnet HTTPS; this local proxy uses plain HTTP.
	# The apt binary and installed config paths are /usr/bin/caddy and
	# /etc/caddy/Caddyfile (see dsv4-caddy.service).
	admin off
	auto_https off
}

http://127.0.0.1:8010 {
	# The site address sets the host matcher; `bind` restricts the actual
	# listener to loopback. Without it Caddy binds 0.0.0.0/::, exposing the
	# auth endpoint on every interface instead of only via Tailscale Serve.
	bind 127.0.0.1

	request_body {
		max_size 10MB
	}

	# The helper authenticates and holds its concurrency slot through the full
	# streamed response. It strips Authorization before forwarding to the engine.
	reverse_proxy 127.0.0.1:8014
}
