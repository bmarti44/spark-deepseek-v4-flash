{
	# TailScale Serve terminates tailnet HTTPS; this local proxy uses plain HTTP.
	# The apt binary and installed config paths are /usr/bin/caddy and
	# /etc/caddy/Caddyfile (see dsv4-caddy.service).
	admin off
	auto_https off
}

:8010 {
	# `bind 127.0.0.1` restricts the listener to loopback (only localhost and
	# the same-host Tailscale Serve proxy can connect). The site address is a
	# bare port with NO host, so it matches every Host header — Tailscale Serve
	# forwards the original tailnet Host (spark-aba1.<tailnet>.ts.net), and a
	# host-specific matcher would drop those to Caddy's empty default handler
	# instead of the auth proxy. Loopback bind is the real access control here.
	bind 127.0.0.1

	request_body {
		max_size 10MB
	}

	# The helper authenticates and holds its concurrency slot through the full
	# streamed response. It strips Authorization before forwarding to the engine.
	reverse_proxy 127.0.0.1:8014
}
